---
import Base from '../layouts/Base.astro';
---
<Base title="Command Map" description="Interactive architecture diagram showing lavra's 30 agents, 27 commands, and 16 skills">
  <iframe
    src="/command-map.html"
    title="lavra Command Map"
    sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox"
    class="w-full border-none"
    style="height: calc(100dvh - 64px);"
  ></iframe>
</Base>
