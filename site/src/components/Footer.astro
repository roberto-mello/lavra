---
// Footer.astro -- Site footer with brand, resources, and platform list
import { Image } from 'astro:assets';
import logo from '../assets/lavra-1-transparent.png';

const resourceLinks = [
  { label: 'Command Map', href: '/command-map' },
  { label: 'Benchmark', href: '/benchmark' },
  { label: 'GitHub', href: 'https://github.com/roberto-mello/lavra', external: true },
  { label: 'Changelog', href: 'https://github.com/roberto-mello/lavra/blob/main/CHANGELOG.md', external: true },
  { label: 'Release Notes', href: 'https://github.com/roberto-mello/lavra/releases/latest', external: true },
  { label: 'Privacy Policy', href: '/docs/privacy' },
];

const platforms = ['Claude Code', 'OpenCode', 'Gemini CLI', 'Cortex Code'];
---

<footer class="py-16 border-t border-border">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto] gap-8 md:gap-16">
      <!-- Brand -->
      <div>
        <Image src={logo} alt="Lavra" width={180} />
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-xs uppercase tracking-wider text-text-dim font-bold mb-3">Resources</h3>
        <ul class="space-y-2">
          {resourceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-text-muted hover:text-text transition-colors"
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Platforms -->
      <div>
        <h3 class="text-xs uppercase tracking-wider text-text-dim font-bold mb-3">Platforms</h3>
        <ul class="space-y-2">
          {platforms.map((name) => (
            <li class="text-sm text-text-dim">{name}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Acknowledgments -->
    <div class="mt-12 pt-6 border-t border-border text-xs text-text-dim leading-relaxed max-w-3xl">
      <p>Built by <a href="https://github.com/roberto-mello" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">Roberto Mello</a>, inspired by <a href="https://every.to/chain-of-thought/compound-engineering-how-every-codes-with-agents" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">compound engineering</a>, extending <a href="https://github.com/EveryInc/compound-engineering-plugin" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">compound-engineering</a> by <a href="https://every.to" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">Every</a>.</p>
      <p class="mt-2">Task tracking by <a href="https://github.com/steveyegge/beads" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">Beads</a>. With ideas from <a href="https://github.com/gsd-build/get-shit-done" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">Get Shit Done</a>, <a href="https://github.com/garrytan/gstack" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">gstack</a> by Garry Tan, <a href="https://x.com/badlogicgames/" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">Mario Zechner</a>, <a href="https://https://simonwillison.net/" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-text transition-colors">Simon Willison</a> and many others. Thanks to my friend Dan for rubber-ducking Lavra.</p>
      <p class="mt-3 italic">Lavra (/ˈla.vɾɐ/) is the Portuguese word for "harvest" — every session plants knowledge that the next one reaps.</p>
      <p class="mt-4">2025-2026 Roberto Mello</p>
    </div>
  </div>
</footer>
