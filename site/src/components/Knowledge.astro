---
import TerminalMockup from './TerminalMockup.astro';
---

<section class="py-32 bg-bg" data-reveal>
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl lg:text-5xl font-bold text-text tracking-tight mb-4">Compounding memory</h2>
    <p class="text-lg text-text-muted mb-16 max-w-2xl">Your agents learn from every session. Knowledge captured today is automatically recalled when relevant.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      {/* Left: Capture */}
      <TerminalMockup title="Capture -- March 2026">
        <div>
          <p><span class="text-accent">$</span> <span class="text-text">bd comments add BD-042</span> <span class="text-amber-400">"LEARNED: OAuth redirect</span></p>
          <p><span class="text-amber-400">  URI must match exactly -- no trailing slash"</span></p>
          <p>&nbsp;</p>
          <p><span class="text-text-dim">Comment added to BD-042</span></p>
          <p>&nbsp;</p>
          <p><span class="text-accent">$</span> <span class="text-text">bd comments add BD-042</span> <span class="text-amber-400">"FACT: Token refresh</span></p>
          <p><span class="text-amber-400">  endpoint rate-limited to 10 req/s per tenant"</span></p>
          <p>&nbsp;</p>
          <p><span class="text-text-dim">Comment added to BD-042</span></p>
          <p>&nbsp;</p>
          <p><span class="text-accent">$</span> <span class="text-text">bd comments add BD-042</span> <span class="text-amber-400">"DECISION: Using PKCE</span></p>
          <p><span class="text-amber-400">  flow -- simpler than client credentials for CLI"</span></p>
          <p>&nbsp;</p>
          <p><span class="text-text-dim">Comment added to BD-042</span></p>
        </div>
      </TerminalMockup>

      {/* Right: Recall */}
      <TerminalMockup title="Recall -- April 2026">
        <div>
          <p><span class="text-accent">[auto-recall]</span> <span class="text-text-muted">Searching knowledge for: oauth, token, auth</span></p>
          <p>&nbsp;</p>
          <p><span class="text-text-muted">Found 3 relevant entries:</span></p>
          <p>&nbsp;</p>
          <p>  <span class="text-accent font-bold">LEARNED:</span> <span class="text-text">OAuth redirect URI must match exactly</span></p>
          <p>  <span class="text-text">         -- no trailing slash</span></p>
          <p>  <span class="text-accent font-bold">FACT:</span>    <span class="text-text">Token refresh endpoint rate-limited to</span></p>
          <p>  <span class="text-text">         10 req/s per tenant</span></p>
          <p>  <span class="text-accent font-bold">DECISION:</span> <span class="text-text">Using PKCE flow -- simpler than client</span></p>
          <p>  <span class="text-text">            credentials for CLI</span></p>
          <p>&nbsp;</p>
          <p><span class="text-text-muted">Injecting into session context...</span></p>
        </div>
      </TerminalMockup>

    </div>

    <p class="text-center text-lg lg:text-xl text-text-muted mt-16">Hit the same problem next month? Your agent already knows the fix.</p>
  </div>
</section>
