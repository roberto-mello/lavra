---
// VideoDemo.astro -- Video placeholder with command map link
---

<section class="py-24 hero-gradient" data-reveal>
  <div class="max-w-7xl mx-auto px-6 text-center">
    <h2 class="text-3xl lg:text-4xl font-bold text-text mb-8">
      See it in action
    </h2>

    <div class="max-w-[960px] mx-auto aspect-video rounded-2xl overflow-hidden border border-border">
      <iframe
        class="w-full h-full"
        src="https://www.youtube.com/embed/qRFJ0BCDMbo"
        title="Lavra demo"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>
