---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Multi-agent workflow engine for Claude Code, OpenCode, and Gemini CLI' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | lavra</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0b0f1a;
      color: #e2e8f0;
      -webkit-font-smoothing: antialiased;
    }
    a { color: #60a5fa; text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav-brand">lavra</a>
    <div class="nav-links">
      <a href="/command-map">Command Map</a>
      <a href="https://github.com/roberto-mello/lavra" target="_blank">GitHub</a>
    </div>
  </nav>
  <slot />
  <style>
    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 24px;
      border-bottom: 1px solid #1f2937;
      background: #111827;
    }
    .nav-brand {
      font-size: 16px;
      font-weight: 700;
      color: #e2e8f0;
      font-family: 'SF Mono', 'Fira Code', monospace;
      letter-spacing: -0.02em;
    }
    .nav-brand:hover { text-decoration: none; color: #93c5fd; }
    .nav-links { display: flex; gap: 20px; }
    .nav-links a { font-size: 13px; color: #9ca3af; }
    .nav-links a:hover { color: #e2e8f0; text-decoration: none; }
  </style>
</body>
</html>
